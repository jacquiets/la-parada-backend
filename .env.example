PROJECT_NAME="La Parada API"

# URL de conexión a la base de datos PostgreSQL de Supabase
# Se encuentra en: Database settings -> Connection string -> URI
DATABASE_URL="postgresql://postgres.[YOUR-PROJECT-REF]:[YOUR-PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres"

# Variables de la API de Supabase
# Se encuentran en: Project settings -> API
